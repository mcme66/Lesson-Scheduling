# Copy to .env for local development (never commit .env)

SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Use a SECRET key (server-side only — never put in HTML).
# Either of the following names is accepted; pick whichever matches the format
# Supabase shows you in the dashboard.
#
#   New format (Supabase Dashboard → Project Settings → API Keys → "Secret keys"):
SUPABASE_SECRET_KEY=sb_secret_your_secret_here
#
#   Legacy format (Supabase Dashboard → Project Settings → API → "service_role"):
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...your_legacy_jwt...
#
# Do NOT use the "Publishable" or "anon" key — they are read-only for the
# browser and won't have permission to write to the schedule table.
